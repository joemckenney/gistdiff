{
  "name": "@gistdiff/core",
  "version": "0.1.0",
  "description": "Core library powering the gistdiff CLI: summarize git diffs via Vercel AI Gateway",
  "keywords": [
    "ai",
    "git",
    "diff",
    "commit",
    "vercel",
    "ai-gateway",
    "ai-sdk"
  ],
  "homepage": "https://github.com/joemckenney/gistdiff#readme",
  "bugs": {
    "url": "https://github.com/joemckenney/gistdiff/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joemckenney/gistdiff.git",
    "directory": "packages/@gistdiff/core"
  },
  "license": "MIT",
  "author": "Joe McKenney <j.mckenney00@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./prompt": {
      "types": "./dist/prompt.d.ts",
      "default": "./dist/prompt.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "clean": "rm -rf dist .turbo",
    "check": "biome check . && tsgo --noEmit",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "^22.15.21",
    "@typescript/native-preview": "catalog:"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.95",
    "ai": "^6.0.157"
  }
}
