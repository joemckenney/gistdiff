{
  "name": "gistdiff",
  "version": "0.1.0",
  "description": "Generate commit messages from a git diff using the Vercel AI Gateway",
  "keywords": [
    "ai",
    "git",
    "diff",
    "commit",
    "commit-message",
    "cli",
    "vercel",
    "ai-gateway"
  ],
  "homepage": "https://github.com/joemckenney/gistdiff#readme",
  "bugs": {
    "url": "https://github.com/joemckenney/gistdiff/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joemckenney/gistdiff.git",
    "directory": "packages/@gistdiff/cli"
  },
  "license": "MIT",
  "author": "Joe McKenney <j.mckenney00@gmail.com>",
  "type": "module",
  "bin": {
    "gistdiff": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsgo --watch",
    "clean": "rm -rf dist .turbo",
    "check": "biome check . && tsgo --noEmit",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@gistdiff/core": "workspace:^",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "^22.15.21",
    "@typescript/native-preview": "catalog:"
  }
}
